# OpenAI (GPT-4o, o3, etc.)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic (Claude)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-5

# Сбер GigaChat
# https://developers.sber.ru/portal/products/gigachat
# Credentials выдаются как Base64(client_id:client_secret)
GIGACHAT_CREDENTIALS=...
# Или раздельно:
# GIGACHAT_CLIENT_ID=...
# GIGACHAT_CLIENT_SECRET=...
GIGACHAT_MODEL=GigaChat-Pro
# Scope: GIGACHAT_API_PERS (физлицо) или GIGACHAT_API_CORP (юрлицо)
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Яндекс YandexGPT / Alice
# https://console.yandex.cloud/ → IAM-токен или API-ключ сервисного аккаунта
YANDEX_API_KEY=...
YANDEX_API_KEY_ID=...
YANDEX_FOLDER_ID=...
YANDEX_MODEL=yandexgpt-pro
# Альтернатива: IAM-токен (короткоживущий, для локального запуска)
# YANDEX_IAM_TOKEN=...
