# Copy this file to config/server.env and fill your private server settings.
# config/server.env is gitignored.

SCORER_REMOTE_LOGS=user@host:/absolute/path/to/shared/logs/
# Optional. Needed when the server stores scoring sidecar files separately.
# SCORER_REMOTE_RESULTS=user@host:/absolute/path/to/data/results/
# SCORER_SSH_PORT=22

# Scoring web auth/session settings. Fill SCORER_SECRET_KEY on the server with
# a private value, for example from:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SCORER_SECRET_KEY=
SCORER_AUTH_DB=
SCORER_COOKIE_SECURE=1
SCORER_SESSION_HOURS=12
