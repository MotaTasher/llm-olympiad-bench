# Public model/runtime configuration. Safe to commit.
#
# Put API keys and tokens only in:
# models/<provider>/secrets/.env
#
# Default model versions are defined in models/<provider>/versions.py
# Override here only when you want a non-default version for a run:
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-sonnet-4-5
# GIGACHAT_MODEL=GigaChat-Max
# YANDEX_MODEL=yandexgpt-lite
# DEEPSEEK_MODEL=deepseek-v4-flash

GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_VERIFY_SSL=false

YANDEX_TEMPERATURE=0.3
YANDEX_MAX_TOKENS=4000

RUB_PER_USD=90

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TEMPERATURE=0.3
