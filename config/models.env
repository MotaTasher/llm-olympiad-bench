# Public model/runtime configuration. Safe to commit.
#
# Put API keys and tokens only in:
# models/<provider>/secrets/.env
#
# Default model versions are defined in models/<provider>/versions.py
# Override here only when you intentionally need a provider-supported
# non-default version for an ad hoc run. Keep committed defaults on the
# strongest active benchmark models.
# OPENAI_MODEL=gpt-5.5
# ANTHROPIC_MODEL=claude-opus-4-8
# GEMINI_MODEL=gemini-3.1-pro-preview
# GIGACHAT_MODEL=GigaChat-2-Max
# XAI_MODEL=grok-4.3
# ZAI_MODEL=glm-5.2
# YANDEX_MODEL=yandexgpt-5.1
# DEEPSEEK_MODEL=deepseek-v4-pro

# Default runner model set. "all" expands to every active model in
# models/*/versions.py, which is the same configured model set shown as
# columns in the scoring UI.
RUNNER_MODELS=all

# Reasoning/output budget controls. These are not secrets.
# Hard limits are provider-specific; no provider guarantees a minimum thinking budget.
RUNNER_MAX_TOKENS=8000

OPENAI_REASONING_EFFORT=high
OPENAI_MAX_COMPLETION_TOKENS=12000

ANTHROPIC_MAX_TOKENS=12000
# Uncomment to enable Claude extended thinking with a hard thinking budget.
# ANTHROPIC_THINKING_BUDGET_TOKENS=8000

GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_VERIFY_SSL=false
GIGACHAT_TEMPERATURE=0.1
GIGACHAT_TOP_P=0.9
GIGACHAT_MAX_TOKENS=8192
GIGACHAT_REPETITION_PENALTY=1.05

YANDEX_TEMPERATURE=0.1
YANDEX_MAX_TOKENS=8000
YANDEX_REASONING_MODE=ENABLED_HIDDEN

RUB_PER_USD=90

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TEMPERATURE=0.3
DEEPSEEK_MAX_TOKENS=8192

GEMINI_THINKING_LEVEL=high
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_TIMEOUT_SECONDS=3600

XAI_BASE_URL=https://api.x.ai/v1
XAI_REASONING_EFFORT=high
XAI_MAX_OUTPUT_TOKENS=8192
XAI_TIMEOUT_SECONDS=3600
XAI_MAX_RETRIES=0

ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
ZAI_THINKING=enabled
ZAI_REASONING_EFFORT=max
ZAI_MAX_TOKENS=8192
ZAI_TIMEOUT_SECONDS=3600
ZAI_MAX_RETRIES=0
